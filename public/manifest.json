{
  "manifest_version": 3,
  "name": "Chase Application Status Viewer",
  "version": "1.0.19",
  "description": "Unofficial tool to visualize Chase Credit Card application status for reconsideration calls.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Check Chase Status",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*.chase.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
